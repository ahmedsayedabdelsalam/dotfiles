{
  "$schema": "https://opencode.ai/config.json",
  "formatter": false,
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "enabled": true
    }
  },
  "plugin": ["opencode-claude-auth@latest"],
  "permission": {
    "bash": {
      "git push *": "ask",
      "git merge *": "ask",
      "git reset *": "ask"
    }
  }
}
